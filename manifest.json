{
  "manifest_version": 3,
  "name": "Cenit New Tab",
  "version": "1.2.0",
  "description": "A beautiful new tab that is highly customizable to meet your preference",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "bookmarks",
    "history",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
